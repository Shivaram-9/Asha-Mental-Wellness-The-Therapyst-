# Recommend Git LFS for large media files. To activate, run:
#   git lfs install
#   git lfs track "assets/videos/*.mp4"
#   git add .gitattributes
#   git commit -m "Track media with Git LFS"

assets/videos/*.mp4 filter=lfs diff=lfs merge=lfs -text
assets/images/*.jpeg filter=lfs diff=lfs merge=lfs -text